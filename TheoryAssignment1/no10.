//10.Write a program to print Fibonacci series of n terms where n is input by user 
import java.util.Scanner;
public class Fibo {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		Scanner input=new Scanner(System.in);
		System.out.println("Enter number of terms=");
		int n=input.nextInt();
		//first two fibonacci number
		int first=0;
		int second=1;
		System.out.println("Fibonacci Series: ");
		//if user enters 0 or negative number
		if(n<=0)
		{
			System.out.println("No terms to print.");
		}//if user wants only first term
		else if(n==1)
		{
			System.out.println(first);
		}//if user wants 2 or more terms
		else {
			System.out.print(first +","+second);
			for(int i=3;i<=n;i++)
			{
				
				int fibonacci=first+second;
				first=second;
				second=fibonacci;
				System.out.print(","+fibonacci );
				
			}
		}
		
	}
}
