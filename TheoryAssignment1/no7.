/*7.	Write a program to enter the numbers till the user wants and
  at the end it should display the count of positive, negative and zeros entered. 
 */

import java.util.Scanner;
public class Numbers {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		Scanner input=new Scanner(System.in);
		System.out.println("how many numbers user wants to input: " );
		int n=input.nextInt();
		int zeroCount=0,posCount=0,negCount=0;
		//Loop n times to take user input numbers
		for(int i=1;i<=n;i++)
		{
			System.out.println("enter number "+i+ "=");
			int number=input.nextInt();
			//Check whether number is positive,negative or zero
			if(number>0)
			{
				posCount=posCount+1;
			}else if(number<0)
			{
				negCount=negCount+1;
			}else
			{
				zeroCount=zeroCount+1;
			}
		}
		System.out.println("Total positive numbers = "+posCount);
		System.out.println("Total negative numbers = "+negCount);
		System.out.println("Total zeros = "+zeroCount);
    }
}
