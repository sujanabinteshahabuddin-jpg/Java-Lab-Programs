/*5.	Write a function that takes in age as input and returns if that person is eligible to vote or not.
A person of age > 18 is eligible to vote.*/

import java.util.Scanner;
public class Person {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		Scanner input=new Scanner(System.in);
		System.out.println("Enter your age= ");
		int age=input.nextInt();
		System.out.println("Result:" +vote(age));
		}
	//This function checks if a person is eligible to vote based on age.
	public static String vote(int age)
	{
		if(age>18)//eligible condition
		{
			return "Eligible to vote.";
		}else
		{
			return "Not eligible to vote.";
		}
	}
}
