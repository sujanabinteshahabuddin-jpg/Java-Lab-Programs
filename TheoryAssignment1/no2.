//2.Write a function to print the sum of all odd numbers from 1 to n.
import java.util.Scanner;
public class OddNumbers {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		Scanner input=new Scanner(System.in);
		//Asking user to enter the value of n
		System.out.println("Enter n (n>1) = ");
		int n=input.nextInt();
		//Calling function to calculate sum of odd numbers
		odd(n);
		}
	//Function to calculate and print sum of odd numbers from 1 to n
	public static void odd(int n) {
		int sum=0;
		//Loop from 1 to n
		for(int i=1;i<=n;i++) {
			//Check if number is odd
			if(i%2!=0) {
				sum=sum+i;//Add odd number to sum
			}
		}
		System.out.println("Sum of all odd numbers from 1 to n= " +sum);
	}
}
