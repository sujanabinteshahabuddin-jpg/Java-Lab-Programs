//blueprint
class Car{
	//class variable
	String brand;
	String model;
	int year;
	char c='a';
	//default constructer
	public Car() {
		//java will creat this when you compile
		brand="unknown";
		model="unknown";
		year=0000;
	}
	//parameterized constructer
	public Car(String brand,String model,int year) {
		this.brand=brand;
		this.model=model;
		this.year=year;
	}
	
  public void displayInfo() {
	  System.out.println("car brand is:"+this.brand+" Model is:"+this.model+" year is:"+this.year+" char is:"+c);
	    }
	
}
