class Student{
	String name;
	String ID;
	double GPA;
	
	public Student()
	{
		name="Unknown";
		ID="0000";
		GPA=0.0;
	}
	public Student(String n,String i,double g)
	{
		this.name=n;
		this.ID=i;
		this.GPA=g;
	}
	public void displayStudentInfo()
	{
		System.out.println("Student name:"+this.name+"\nStudent ID:"+this.ID+"\nStudent CGPA:"+this.GPA);
	}
	
}
